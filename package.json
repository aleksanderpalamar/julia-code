{
  "name": "juliacode",
  "version": "0.3.4",
  "description": "Julia Code (juju) - AI coding assistant TUI powered by local models via Ollama",
  "license": "GPL-3.0-only",
  "type": "module",
  "bin": {
    "juju": "dist/juju.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx juju.ts",
    "dev": "tsx watch juju.ts",
    "build": "tsc && node scripts/fix-shebang.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "11.10.0",
    "cli-highlight": "2.1.11",
    "dotenv": "16.6.1",
    "ink": "5.2.1",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0",
    "minimatch": "10.2.4",
    "react": "18.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/minimatch": "5.1.2",
    "@types/node": "22.19.15",
    "@types/react": "18.3.28",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
